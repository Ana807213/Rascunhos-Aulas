package com.example.primeiroapp

import android.os.Bundle
import android.view.View
import android.widget.EditText
import android.widget.Toast
import androidx.activity.enableEdgeToEdge
import androidx.appcompat.app.AppCompatActivity
import androidx.core.view.ViewCompat
import androidx.core.view.WindowInsetsCompat

class MainActivity : AppCompatActivity() {
    lateinit var primeirovalor : EditText
    lateinit var segundovalor : EditText


    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContentView(R.layout.activity_main)
        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main)) { v, insets ->
            val systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars())
            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom)
            insets
        }
        Toast.makeText(this, "Bem vindo a sua primeira calculadora ", Toast.LENGTH_LONG).show()
        //                       onde         / mensagem /                     duraçao
        primeirovalor = findViewById(R.id.primeirovalor)
        segundovalor = findViewById(R.id.segundovalor)
    }
    fun BotaoSoma(view: View){
        var valorum = primeirovalor.text.toString().toInt()
        var valordois =  segundovalor.text.toString().toInt()
        var soma = valorum + valordois
        Toast.makeText(this, "O resultado da soma é: $soma ", Toast.LENGTH_LONG).show()

    }
    fun BotaoSub(view: View){
        var valorum = primeirovalor.text.toString().toInt()
        var valordois =  segundovalor.text.toString().toInt()
        var sub = valorum - valordois
        Toast.makeText(this, "O resultado da subtracao é: $sub ", Toast.LENGTH_LONG).show()

    }
    fun BotaoDiv(view: View){
        var valorum = primeirovalor.text.toString().toInt()
        var valordois =  segundovalor.text.toString().toInt()
        var div = valorum / valordois
        Toast.makeText(this, "O resultado da divisao é: $div ", Toast.LENGTH_LONG).show()

    }

    fun BotaoMul(view: View){
        var valorum = primeirovalor.text.toString().toInt()
        var valordois =  segundovalor.text.toString().toInt()
        var mul = valorum * valordois
        Toast.makeText(this, "O resultado da multiplicacao é: $mul ", Toast.LENGTH_LONG).show()

    }
    //aqui dentro
}
