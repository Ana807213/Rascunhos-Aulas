def reconstruct_path(came_from, start, goal):
    path = [goal]

    while goal != start:
        """
        enquanto nao chegar na origem
        """

        # vai voltando um passo na arvore
        # Bucharest <- Cidade 1 <- Cidade 2 .... Inicio
        goal = came_from[goal]
        path.append(goal)

    path.reverse()
    return path


