def greedy_best_first_search(graph, heuristic, start, goal):
    """
    grap - o mapa
    heuristic - a heuristica
    start -de onde esta partindo
    goal - onde quer chegar
    """

    # separar o que foi explorado do nao explorado
    frontier = []

    # inserindo nó inicial (Arad)
    # h(n) = h(n)
    heapq.heappush(frontier, (heuristic[start], start))

    """
    Sibiu <--- Arad
    """
    came_from = {}

    """
    Conjunto de nós ja visitados(expandidos)
    Evita ciclo infinito;
    Se torna uma busca rapida - Big O (1)
    """
    visited = set()

    """
    Enquanto houver nós para explorar, faça recursivamente.
    Se a fronteira esvaziar -> nao existe solução.
    """

    while frontier:

        """
        Remove o nó com menor heuristica
        '_' ignora o valor da heuristica
        'current' = recebe a cidade
        """
        _, current = heapq.heappop(frontier)
        print(f"Nó Expandido: {current}")

        if current == goal:
            return reconstruct_path(came_from, start, goal)

        # senao marca como visitado
        visited.add(current)

        for neighbor in graph[current]:
            """
            Procura vizinhos para seguir viagem
            """
            if neighbor not in visited:

                """
                Insere vizinho na fronteira
                """
                heapq.heappush(frontier, (heuristic[neighbor], neighbor))
                came_from[neighbor] = current

    """
    Se nao encontrar solucao , retorna "none"
    """
    return None


