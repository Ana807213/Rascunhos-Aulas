def binary_search(array, key, start, end):
    """
    Busca binária em um array ordenado
    Retorna o índice do elemento ou -1 se não encontrar
    """

    while start <= end:
        # calcular o índice do meio
        mid = start + (end - start) // 2

        # verificar se o elemento do meio é o procurado
        if array[mid] == key:
            return mid

        elif array[mid] < key:
            # elimina a metade esquerda
            start = mid + 1
        else:
            # elimina a metade direita
            end = mid - 1

    return -1  # elemento não encontrado

